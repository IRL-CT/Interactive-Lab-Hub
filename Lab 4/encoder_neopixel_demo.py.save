# encoder_neopixel_demo.py
import time, board
from adafruit_seesaw import seesaw, rotaryio, digitalio, neopixel

# --- I2C & device ---
ss = seesaw.Seesaw(board.I2C(), addr=0x36)

# 校验产品ID（4991为 I2C QT Rotary Encoder）
prod = (ss.get_version() >> 16) & 0xFFFF
print(f"Found product {prod} (expect 4991)")

# --- Inputs ---
ss.pin_mode(24, ss.INPUT_PULLUP)         # 按键
button = digitalio.DigitalIO(ss, 24)
enc = rotaryio.IncrementalEncoder(ss)
last_pos = None

# --- NeoPixel (pin 6, 1 pixel) ---
pix = neopixel.NeoPixel(ss, 6, 1)
pix.brightness = 0.4

def hsv_to_rgb(h, s, v):
    # h: 0-1, s: 0-1, v: 0-1
    import colorsys
    r, g, b = colorsys.hsv_to_rgb(h, s, v)
    return (int(r*255), int(g*255), int(b*255))

hue = 0.0     # 色相
sat = 1.0
val = 1.0
bright_levels = [0.15, 0.4, 0.8]
b_idx = 1

print("Rotate to change color, press to toggle brightness.")
while True:
    # 读取编码器
    pos = -enc.position  # 让顺时针为正
    if pos != last_pos:
        last_pos = pos
        # 每一步改变一点色相
        hue = (pos % 360) / 360.0
        pix[0] = hsv_to_rgb(hue, sat, val)

    # 读取按钮（低电平为按下）
    if not button.value:
        # 去抖：等k     while not button.value:
            time.sleep(0.02)
        b_idx = (b_idx + 1) % len(bright_levels)
        pix.brightness = bright_levels[b_idx]
        print(f"Brightness {pix.brightness}")

    time.sleep(0.02)
        while not button.value:
            time.sleep(0.02)
        b_idx = (b_idx + 1) % len(bright_levels)
        pix.brightness = bright_levels[b_idx]
        print(f"Brightness {pix.brightness}")

    time.sleep(0.02)
